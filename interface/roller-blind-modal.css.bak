  overflow: hidden;
  transform-origin: top center;
  transition: height 0.7s cubic-bezier(0.25,1,0.3,1);
}

/* Kéo rèm xuống */
.upgrade-prompt-overlay.active .upgrade-prompt-modal {
  height: auto;
  max-height: 85vh;
  animation: curtainDrop 0.7s cubic-bezier(0.25,1,0.3,1);
}
@keyframes curtainDrop {
  0% { height:0; opacity:0;}
  90% { height:auto; max-height:87vh; opacity:1;}
  100% { height:auto; max-height:85vh; opacity:1;}
}

/* Nội dung fade-in */
.upgrade-prompt-inner {
  padding: 36px 32px 50px 32px;
  opacity: 0;
  transform: translateY(20px);
  transition: opacity 0.6s ease, transform 0.6s ease;
