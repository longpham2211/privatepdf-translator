}

/* Responsive */
@media (max-width:800px){
  .upgrade-layout-container {
    grid-template-columns:1fr;
  }
  .upgrade-column-left { align-items:center; text-align:center;}
  .upgrade-column-right { position:static; margin-top:20px;}
}
