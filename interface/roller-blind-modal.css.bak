/*
=================================================
  ROLLER BLIND STYLE MODAL - "TẤM RÈM"
=================================================
*/

/* === OVERLAY === */
.upgrade-prompt-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.65);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  z-index: 1001;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  overflow: hidden;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.4s cubic-bezier(0.4, 0, 0.2, 1), 
              visibility 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.upgrade-prompt-overlay.active {
  opacity: 1;
  visibility: visible;
}

/* === Rèm chính === */
.upgrade-prompt-modal {
  width: 100%;
  max-width: 100%;
  height: 0;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(18px);
  box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
  border-bottom-left-radius: 30px;
  border-bottom-right-radius: 30px;
  overflow: hidden;
  transform-origin: top center;
  transition: height 0.8s cubic-bezier(0.25, 1, 0.3, 1);
}

/* Khi mở rèm */
.upgrade-prompt-overlay.active .upgrade-prompt-modal {
  height: auto;
  max-height: 85vh;
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4);
  animation: curtainDrop 0.8s cubic-bezier(0.25, 1, 0.3, 1);
}

@keyframes curtainDrop {
  0% { height: 0; opacity: 0; }
  90% { height: auto; max-height: 87vh; opacity: 1; }
  100% { height: auto; max-height: 85vh; opacity: 1; }
}

/* === Nội dung bên trong === */
.upgrade-prompt-inner {
  height: 100%;
  overflow-y: auto;
  padding: 40px 32px 60px 32px;
  opacity: 0;
  transform: translateY(20px);
  transition: opacity 0.6s ease, transform 0.6s ease;
  transition-delay: 0.4s;
}

.upgrade-prompt-overlay.active .upgrade-prompt-inner {
  opacity: 1;
  transform: translateY(0);
}

/* === Layout 2 cột đẹp === */
.upgrade-layout-container {
  display: grid;
  grid-template-columns: 1.3fr 1fr;
  gap: 40px;
  max-width: 960px;
  margin: 0 auto;
  align-items: flex-start;
}

/* --- Cột trái: giới thiệu & CTA --- */
.upgrade-column-left {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  text-align: left;
}

.upgrade-column-left h2 {
  font-size: 2rem;
  font-weight: 800;
  margin-bottom: 12px;
  background: linear-gradient(90deg, #16a34a, #0ea5e9);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.upgrade-column-left .upgrade-prompt-subtitle {
  font-size: 1.05rem;
  color: #475569;
  line-height: 1.6;
  margin-bottom: 24px;
}

/* Illustration */
.upgrade-illustration {
  width: 100%;
  max-width: 280px;
  margin-bottom: 24px;
}
.upgrade-illustration svg {
  width: 100%;
  height: auto;
}

/* Nút CTA */
.upgrade-prompt-actions {
  display: flex;
  flex-direction: column;
  gap: 14px;
  width: 100%;
  max-width: 360px;
}

.upgrade-btn-primary,
.upgrade-btn-secondary {
  width: 100%;
  padding: 14px 22px;
  font-size: 1rem;
  font-weight: 700;
  border-radius: 12px;
  cursor: pointer;
  transition: all 0.25s ease;
}

/* Nút chính gradient xanh dương đậm */
.upgrade-btn-primary {
  background: linear-gradient(135deg, #3b82f6, #1e40af);
  color: #fff;
  box-shadow: 0 6px 20px rgba(59, 130, 246, 0.4);
}
.upgrade-btn-primary:hover {
  transform: translateY(-3px);
  box-shadow: 0 10px 30px rgba(59, 130, 246, 0.55);
}

/* Nút phụ */
.upgrade-btn-secondary {
  background: #f3f4f6;
  color: #374151;
  border: 1px solid #e5e7eb;
}
.upgrade-btn-secondary:hover {
  background: #e5e7eb;
}

/* Link đăng nhập */
.upgrade-prompt-login-text {
  margin-top: 12px;
  font-size: 0.9rem;
  color: #6b7280;
}
.upgrade-prompt-login-link {
  color: #0ea5e9;
  font-weight: 600;
  text-decoration: none;
}
.upgrade-prompt-login-link:hover {
  text-decoration: underline;
}

/* --- Cột phải: danh sách tính năng --- */
.upgrade-column-right {
  background: rgba(248, 249, 250, 0.95);
  border: 1px solid #e9ecef;
  border-radius: 16px;
  padding: 28px 32px;
  position: sticky;
  top: 40px;
}

.pro-badge {
  display: inline-block;
  background: #ffc107;
  color: #343a40;
  font-weight: 700;
  border-radius: 6px;
  padding: 6px 12px;
  font-size: 0.9rem;
  letter-spacing: 0.5px;
}

.pro-features-list {
  list-style: none;
  padding: 0;
  margin: 24px 0 0 0;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.pro-features-list li {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  font-size: 1rem;
  color: #343a40;
  line-height: 1.5;
  font-weight: 500;
  position: relative;
  padding-left: 28px;
  transition: transform 0.2s ease, color 0.2s ease;
}

.pro-features-list li::before {
  content: '✔';
  position: absolute;
  left: 0;
  top: 0;
  font-weight: 700;
  color: #ffc107;
  font-size: 1.1rem;
  transition: transform 0.2s ease;
}

.pro-features-list li:hover {
  color: #16a34a;
  transform: translateX(4px);
}
.pro-features-list li:hover::before {
  transform: scale(1.3);
}

/* === Dark Mode === */
body.dark-mode .upgrade-prompt-modal {
  background: rgba(31, 41, 55, 0.95);
  backdrop-filter: blur(18px);
}
body.dark-mode .upgrade-column-left h2 {
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background: linear-gradient(90deg, #22c55e, #3b82f6);
}
body.dark-mode .upgrade-column-left .upgrade-prompt-subtitle {
  color: #9ca3af;
}
body.dark-mode .upgrade-illustration svg path {
  stroke: #9ca3af;
}
body.dark-mode .upgrade-prompt-login-text {
  color: #9ca3af;
}
body.dark-mode .upgrade-column-right {
  background: #374151;
  border-color: #4b5563;
}
body.dark-mode .pro-badge {
  background: #f59e0b;
  color: #1f2937;
}
body.dark-mode .pro-features-list li {
  color: #d1d5db;
}
body.dark-mode .pro-features-list li::before {
  color: #f59e0b;
}
body.dark-mode .upgrade-btn-secondary {
  background-color: #4b5563;
  color: #f3f4f6;
  border-color: #525f73;
}
body.dark-mode .upgrade-btn-secondary:hover {
  background-color: #525f73;
}

/* === Responsive === */
@media (max-width: 800px) {
  .upgrade-layout-container {
    grid-template-columns: 1fr;
    gap: 32px;
  }
  
  .upgrade-column-left {
    align-items: center;
    text-align: center;
  }

  .upgrade-column-right {
    position: static;
  }

  .upgrade-prompt-login-text {
    text-align: center;
  }
}
/* Overlay */
.upgrade-prompt-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.6);
  backdrop-filter: blur(6px);
  z-index: 1001;
